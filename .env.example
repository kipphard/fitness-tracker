# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Encryption key, and the JWT signing fallback. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Postgres (used by docker-compose to provision the db service for local dev)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=fitness

# SQLAlchemy connection URL the api uses. Inside docker-compose the host is "db".
DATABASE_URL=postgresql+psycopg://app:app@db:5432/fitness

# Host port the api is published on. Change if 8000 is already taken on your machine.
API_PORT=8000
# Host port mapped to Postgres. Change if 5432 is already taken locally.
DB_PORT=5432
